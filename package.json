{
  "name": "@shakil-dev/shakil-stack",
  "version": "2.2.10",
  "description": "Full-stack EchoNet-style project generator CLI",
  "keywords": [
    "shakil-stack",
    "echonet",
    "prisma",
    "nextjs",
    "express",
    "better-auth",
    "fullstack",
    "generator",
    "cli"
  ],
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "shakil-stack": "dist/index.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakil-ahmed-billal/shakil-stack-cli.git"
  },
  "bugs": {
    "url": "https://github.com/shakil-ahmed-billal/shakil-stack-cli/issues"
  },
  "homepage": "https://xhakil.vercel.app/blog/shakil-stack-cli-guide",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/bin/index.ts --format esm --outDir dist --clean --minify --target node20 && mkdir -p dist/templates && cp -r src/templates/public-assets dist/templates/",
    "dev": "tsx src/bin/index.ts",
    "start": "node dist/bin/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.0",
    "@types/ora": "^3.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
